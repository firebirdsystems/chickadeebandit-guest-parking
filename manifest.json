{
  "id": "guest-parking",
  "name": "Guest Parking Passes",
  "version": "1.0.0",
  "description": "The board sets how many guest parking passes are available each night; residents claim an open pass first-come, and can release or move it. Atomic capacity claims keep the lot from being overbooked.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "organization",
  "tags": ["hoa", "parking", "guest", "passes", "reservations", "slot-claims"],
  "data_access": {
    "reads": ["family.members", "family.groups"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "db_plaintext_columns": ["capacity", "guest_name", "vehicle"],
  "row_policies": {
    "nights": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "status",
      "everyone_values": ["open", "closed"],
      "privileged_groups": [
        { "settings_table": "settings", "settings_key": "board_group_id" }
      ],
      "write_privileged_only": true
    },
    "claims": {
      "kind": "endpoint_only",
      "read": "everyone"
    },
    "settings": {
      "kind": "app_config"
    }
  },
  "admin_config": {
    "settings_table": "settings",
    "keys": ["board_group_id", "default_capacity"]
  },
  "slot_claims": {
    "slot_table": "nights",
    "slot_id_column": "id",
    "capacity_column": "capacity",
    "slot_status_column": "status",
    "slot_open_values": ["open"],
    "claims_table": "claims",
    "claim_id_column": "id",
    "slot_fk_column": "night_id",
    "member_column": "member_id",
    "created_at_column": "claimed_at",
    "one_claim_per_member": true,
    "allow_release": true,
    "allowed_columns": ["guest_name", "vehicle"],
    "max_text_lengths": { "guest_name": 120, "vehicle": 80 }
  },
  "nav": { "label": "Guest Parking" },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "🅿️",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["upcoming_nights", "claimed_passes"]
  }
}
